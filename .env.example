# ─── Patent PreCheck — Environment Variables ───
# Copy this file to .env and fill in real values. .env is gitignored.

# ═══ ANTHROPIC ═══════════════════════════════════════════════════════════
# Your Anthropic API key — get from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ═══ EMBEDDING PROVIDER (choose one) ═════════════════════════════════════
# Voyage AI (Anthropic-recommended for use with Claude)
VOYAGE_API_KEY=pa-...
# OR OpenAI (fallback)
# OPENAI_API_KEY=sk-...
#
# Dimension locked at 1536. Voyage voyage-3-large is called with
# output_dimension=1536; OpenAI text-embedding-3-small (fallback) is
# natively 1536. Schema uses vector(1536). Do not change without a migration.
EMBEDDING_PROVIDER=voyage
EMBEDDING_MODEL=voyage-3-large
EMBEDDING_DIMENSIONS=1536

# ═══ DATABASE ════════════════════════════════════════════════════════════
# Local dev: matches docker-compose.yml in infra/docker/
DATABASE_URL=postgresql://ppc:ppc_dev_pass@localhost:5433/patentprecheck
# Discrete vars consumed by docker-compose for the Postgres container.
# Keep these in sync with DATABASE_URL above.
POSTGRES_USER=ppc
POSTGRES_PASSWORD=ppc_dev_pass
POSTGRES_DB=patentprecheck
POSTGRES_PORT=5433

# ═══ STRIPE (for $69.99 / $29.99 products) ═══════════════════════════════
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ONE_TIME=price_...
STRIPE_PRICE_REANALYZE=price_...

# ═══ LEGAL INTELLIGENCE NOTIFIER (existing) ══════════════════════════════
SENDGRID_API_KEY=SG....
SLACK_WEBHOOK=https://hooks.slack.com/services/...
NOTIFY_EMAIL_TO=kjberk13@gmail.com

# ═══ SITE ═══════════════════════════════════════════════════════════════
SITE_URL=https://patentprecheck.com

# ═══ WORKER TOKENS ═══════════════════════════════════════════════════════
# GitHub Personal Access Token — REQUIRED for the github-search worker.
# Fine-grained token with public-repo read is sufficient.
GITHUB_TOKEN=ghp_...
# USPTO Open Data Portal API key — REQUIRED for the uspto-patentsview worker.
# Register at https://developer.uspto.gov (free tier available) after the
# Oct 2024 migration. Sent as X-Api-Key on every request.
USPTO_API_KEY=
# Optional override if USPTO moves the PatentsView URL under ODP.
# PATENTSVIEW_ENDPOINT=https://search.patentsview.org/api/v1/patent/
SEMANTIC_SCHOLAR_API_KEY=...
IEEE_API_KEY=...
# Google Patents via BigQuery (Phase 2.4.2)
BIGQUERY_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# ═══ RUNTIME ═════════════════════════════════════════════════════════════
LOG_LEVEL=info
INGESTION_BATCH_SIZE=100
